# Openship API — SaaS development example.
# Copy to .env.saas for SaaS-mode development. Do not commit real secrets.
#
# SINGLE knob — OPENSHIP_TARGET — picks the runtime-target row. The
# table at packages/core/src/runtime-config.ts is the source of URLs.
# Two valid values:
#   OPENSHIP_TARGET=local        → self-hosted (default if unset)
#   OPENSHIP_TARGET=cloud-saas   → the SaaS, on api.openship.io OR a
#                                  tunneled localhost binding
# No NODE_ENV magic, no CLOUD_MODE-based URL inference. Period.

NODE_ENV=development

OPENSHIP_TARGET=cloud-saas
CLOUD_MODE=true
DEPLOY_MODE=cloud

DATABASE_URL=

BETTER_AUTH_SECRET=change-me-in-production

# Required outside desktop mode. Fronts trusted Electron↔API endpoints
# (/setup, /desktop-auth-start). Boot refuses to start without it.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_TOKEN=change-me-32-byte-random-hex

# Required for cloud deployments.
OBLIEN_CLIENT_ID=
OBLIEN_CLIENT_SECRET=
# Returned by Oblien when the org's webhook is registered via
# client.webhooks.create. Used to verify HMAC on inbound deliveries to
# /api/billing/oblien-webhook. Without it the endpoint returns 503 — we
# never accept unverified webhook traffic. Operator action: register the
# webhook and persist the returned secret here.
OBLIEN_WEBHOOK_SECRET=

# Required for GitHub App mode.
GITHUB_APP_ID=
GITHUB_APP_SLUG=openship-io
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

SYSTEM_DEBUG_LOGS=false
